{
  "manifest_version": 2,
  "name": "Simple Jira Worklog",
  "version": "1.0.0",
  "description": "Track work hours and log time to Jira Cloud tickets. View daily logged time, search tickets, and submit worklogs directly from your browser.",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "permissions": [
    "storage",
    "*://*.atlassian.net/*",
    "*://*.jira.com/*"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.svg"
    },
    "default_title": "Simple Jira Worklog",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{e8a5b5c3-4d2f-4a1e-9b3c-7f8d6e5a4b3c}",
      "strict_min_version": "109.0"
    }
  }
}
